backend/fuzz/target/
# cargo-fuzz sub-crate build + runtime output
backend/fuzz/fuzz/target/
backend/fuzz/fuzz/corpus/
backend/fuzz/fuzz/artifacts/

# ── Vite build assets (unused boilerplate) ──
frontend/src/assets/
