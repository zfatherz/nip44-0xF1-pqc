.claude/
.vscode/
.idea/
*.swp
*.swo
*.swn
*~

# ── Dependencies ──
node_modules/

# ── Build outputs ──
dist/
dist-ssr/
build/
out/
*.local

# ── Logs ──
*.log
*.txt

# ── Environment & secrets ──
.env
.env.*

# ── Runtime data ──
*.db
*.pid

